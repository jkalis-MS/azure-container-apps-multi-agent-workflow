# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_TTS_DEPLOYMENT=tts-hd
# Optional: set if OpenAI resource is in a different RG than your container apps
# AZURE_OPENAI_RESOURCE_GROUP=your-openai-rg

# Azure Subscription (for Sandboxes API)
AZURE_SUBSCRIPTION_ID=your-subscription-id
ACA_RESOURCE_GROUP=your-resource-group
ACA_SANDBOX_GROUP=your-sandbox-group
ACR_NAME=your-acr-name

# Service URLs (for local dev — in Azure these are set by Bicep)
SIMULATOR_URL=http://localhost:3001
BLOG_GEN_URL=http://localhost:3002
NARRATION_GEN_URL=http://localhost:3003
